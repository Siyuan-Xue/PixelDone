<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Todo/domain data remains eligible. Derived sync state is always rebuilt. -->
    <cloud-backup>
        <exclude domain="database" path="pixel_done_sync.db" />
        <exclude domain="database" path="pixel_done_sync.db-shm" />
        <exclude domain="database" path="pixel_done_sync.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="pixel_done_sync.db" />
        <exclude domain="database" path="pixel_done_sync.db-shm" />
        <exclude domain="database" path="pixel_done_sync.db-wal" />
    </device-transfer>
</data-extraction-rules>
